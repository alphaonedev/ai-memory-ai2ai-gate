{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alphaonedev.github.io/ai-memory-ai2ai-gate/releases/schema.json",
  "title": "a2a-gate release summary",
  "description": "Release-blocking schema for releases/<version>/summary.json. The landing page reads the highest-semver summary.json in releases/ as 'current'. Either 'phases' (ship-gate-style) or 'cells' (a2a-gate-style) must be present and non-empty. Validated by .github/workflows/release-summary-gate.yml on every v* tag push.",
  "type": "object",
  "required": [
    "version",
    "campaign_run_id",
    "pass_count",
    "fail_count",
    "wall_seconds",
    "verdict",
    "date"
  ],
  "anyOf": [
    { "required": ["cells"]  },
    { "required": ["phases"] }
  ],
  "additionalProperties": true,
  "properties": {
    "version":          { "type": "string", "pattern": "^v\\d+\\.\\d+\\.\\d+(?:\\.\\d+)?(?:-[A-Za-z0-9.-]+)?$" },
    "campaign_run_id":  { "type": "string", "minLength": 1 },
    "date":             { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "wall_seconds":     { "type": "integer", "minimum": 0 },
    "wall_human":       { "type": "string" },
    "pass_count":       { "type": "integer", "minimum": 0 },
    "fail_count":       { "type": "integer", "minimum": 0 },
    "verdict":          { "type": "string", "enum": ["pass", "fail"] },
    "headline":         { "type": "string" },
    "agent_group":      { "type": "string" },
    "tls_mode":         { "type": "string" },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["cell", "pass", "pass_count", "fail_count"],
        "properties": {
          "cell":         { "type": "string" },
          "agent_group":  { "type": "string" },
          "tls_mode":     { "type": "string" },
          "pass":         { "type": "boolean" },
          "pass_count":   { "type": "integer", "minimum": 0 },
          "fail_count":   { "type": "integer", "minimum": 0 },
          "scenario_total": { "type": "integer", "minimum": 0 },
          "wall_seconds": { "type": "integer", "minimum": 0 },
          "wall_human":   { "type": "string" },
          "notes":        { "type": "string" }
        }
      }
    },
    "phases":           { "type": "array" },
    "scenarios_closed": { "type": "array" },
    "evidence":         { "type": "object" },
    "release":          { "type": "object" }
  }
}
