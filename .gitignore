# Python bytecode (from local py_compile syntax checks)
__pycache__/
*.pyc
*.pyo

# Nested checkouts used for reference only (never committed from this repo)
/ai-memory-mcp/

# Local runner artifacts
phase-reports/
/tmp-*

# Docker build context — staged ai-memory binary is produced out-of-tree
# by `cargo build --release` and not suitable for committing.
docker/bin/ai-memory

# Ephemeral TLS material generated per cert round by docker/gen-tls.sh.
# CA private keys + server/client keys must NEVER be committed.
docker/tls/

# Local mkdocs venv + build output
.venv/
venv/
site/

# Editor / OS noise
*.swp
.DS_Store
